# Database Configuration
DB_HOST = "your_host"
DB_NAME = "your_database"
DB_USER = "your_username"
DB_PASS = "your_password"
DB_PORT = "your_port"  # Default is 3306 for MySQL, 5432 for PostgreSQL

# Server Configuration
SERVER_IP = "your_server_ip"  # e.g., "192.168.1.100" or "example.com"

# Google Maps API Key (for school registration)
GOOGLE_MAPS_API_KEY = "your_google_maps_api_key"

# Email Configuration
# ==================
# IMPORTANT: Choose your email backend:
#
# 1. DEVELOPMENT MODE (emails printed to console, NOT sent):
#    EMAIL_BACKEND = "django.core.mail.backends.console.EmailBackend"
#
# 2. PRODUCTION MODE (emails actually sent via SMTP):
#    EMAIL_BACKEND = "django.core.mail.backends.smtp.EmailBackend"
#
# For Gmail SMTP, you MUST use an App Password (not your regular password):
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Create a new app password for "Django Mail"
# 3. Use that 16-character password below (no spaces)
# 4. Less secure app access is NO LONGER supported by Gmail
#
EMAIL_BACKEND = "django.core.mail.backends.console.EmailBackend"  # Change to smtp.EmailBackend to send real emails
EMAIL_HOST = "smtp.gmail.com"  # SMTP server (Gmail)
EMAIL_PORT = "587"  # TLS port for Gmail (use 465 for SSL)
EMAIL_USE_TLS = "True"  # Use TLS encryption
EMAIL_HOST_USER = "your_email@gmail.com"  # Your Gmail address
EMAIL_HOST_PASSWORD = "your_app_password_here"  # Gmail App Password (16 chars, no spaces)
DEFAULT_FROM_EMAIL = "noreply@digitmile.com"  # Sender email shown in emails
SITE_URL = "http://localhost:8000"  # Your site URL (for email links)
