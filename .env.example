# DigitMile Environment Configuration
# Copy this file to .env and fill in your values

# Database Configuration
DB_HOST=db
DB_NAME=digitmile
DB_USER=digitmile
DB_PASS=your-strong-password-here
DB_PORT=5432

# Django Configuration
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
SERVER_IP=backend
ALLOWED_HOSTS=backend,localhost,127.0.0.1

# API Keys
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=noreply@digitmile.com
SITE_URL=http://localhost:8000

# Django Superuser (for automatic creation on startup)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@digitmile.com
DJANGO_SUPERUSER_PASSWORD=changeme-strong-password

# Shared secret for internal service-to-service endpoints (currently: the
# compactor cron container's POST to the weekly-compaction trigger). The
# compactor service in docker-compose.prod.yml must hold the SAME value.
# Generate with: openssl rand -hex 32
INTERNAL_API_TOKEN=replace-me-with-a-strong-random-value

# Add your additional API keys and secrets below
# ANOTHER_API_KEY=your-key-here
